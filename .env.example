# Configuração do Banco de Dados PostgreSQL
# (O 'db' no DB_HOST é o nome do serviço no docker-compose.yml)
DB_HOST=db
DB_NAME=portal_rh_db
DB_USER=portal_rh_user
DB_PASS=mudar_para_uma_senha_forte_e_segura

# Configuração do Redis
# (O 'redis' no REDIS_HOST é o nome do serviço no docker-compose.yml)
REDIS_HOST=redis
REDIS_PORT=6379

# Credenciais do Cloudflare R2 (Armazenamento de Arquivos)
# Substitua pelos seus valores reais
AWS_ACCESS_KEY_ID=SEU_ACCESS_KEY_ID_DO_R2
AWS_SECRET_ACCESS_KEY=SUA_SECRET_KEY_DO_R2
AWS_STORAGE_BUCKET_NAME=nome-do-seu-bucket-no-r2
AWS_S3_ENDPOINT_URL=https://<seu-account-id>.r2.cloudflarestorage.com

# Chave do Google Gemini (IA Gratuita para Verificacao Visual)
GEMINI_API_KEY=sua-chave-api-gemini-gratuita